# Copy to .env and fill in local values. Sourced by Makefile targets and scripts/*.sh.
#
# Terraform reads endpoint/insecure from terraform.tfvars — only the API token
# is taken from the environment when proxmox_api_token is null in tfvars.
export PROXMOX_VE_API_TOKEN="user@pam!token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# SSH to cloud-init VMs (must match terraform ssh_user / key used in tfvars)
export ANSIBLE_USER="ubuntu"
export ANSIBLE_PRIVATE_KEY_FILE="$HOME/.ssh/id_ed25519"
