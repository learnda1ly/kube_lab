# Copy to .env and fill in local values. Sourced by scripts/rebuild.sh when present.
export PROXMOX_VE_ENDPOINT="https://proxmox.example.local:8006/"
export PROXMOX_VE_API_TOKEN="user@pam!token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
export PROXMOX_VE_INSECURE="true"

# SSH user on cloud-init VMs (must match terraform ssh_user)
export ANSIBLE_USER="ubuntu"