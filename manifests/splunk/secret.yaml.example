# Copy to secret.yaml and set a real password before apply.
#   cp secret.yaml.example secret.yaml
# Password must meet Splunk policy (length, complexity).
# secret.yaml is gitignored — do not commit it.
apiVersion: v1
kind: Secret
metadata:
  name: splunk-secrets
  namespace: splunk
  labels:
    app.kubernetes.io/name: splunk
type: Opaque
stringData:
  password: "ChangeMeNow!123"
